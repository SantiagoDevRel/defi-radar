# =============================================================================
# DeFi Radar — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# Server
PORT=3001
NODE_ENV=development

# =============================================================================
# RPC Endpoints — override the defaults in src/config/chains.ts
# Public RPCs are used by default; add private keys for higher rate limits.
# =============================================================================

# Ethereum (get a free key at https://www.alchemy.com or https://www.infura.io)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# BNB Chain (public RPC available, but private is more reliable)
BNB_RPC_URL=https://bsc-dataseed.binance.org

# Base
BASE_RPC_URL=https://mainnet.base.org

# Arbitrum
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com

# Avalanche
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Stellar Horizon
STELLAR_HORIZON_URL=https://horizon.stellar.org

# =============================================================================
# Security
# =============================================================================

# API key for write endpoints (refresh triggers). Leave empty to disable auth.
API_SECRET_KEY=change_me_to_a_random_string

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Database
# =============================================================================

# Path to the SQLite database file (relative to project root)
DB_PATH=./data/defi-radar.db

# How many days of historical snapshots to retain
DB_RETENTION_DAYS=90

# =============================================================================
# Feature Flags
# =============================================================================

# Default auto-refresh interval in minutes (0 = disabled)
AUTO_REFRESH_INTERVAL_MINUTES=0

# Minimum TVL in USD to include a pool in results
MIN_TVL_USD=100000

# Log level: error | warn | info | debug
LOG_LEVEL=info
